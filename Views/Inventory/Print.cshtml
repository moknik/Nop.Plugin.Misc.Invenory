@model InventoryPageModel

@{
    Layout = null;
    var f = Model.InventoryFilters;
    var manufacturerName = f.InvManufacturerId.HasValue
        ? Model.InventoryManufacturers.FirstOrDefault(m => m.Id == f.InvManufacturerId.Value).Name
        : null;
    var categoryName = f.InvCategoryId.HasValue
        ? Model.InventoryCategories.FirstOrDefault(c => c.Id == f.InvCategoryId.Value).Name
        : null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@T("Plugins.Misc.Moknik.Inventory.Tab.Inventory") — @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</title>
    <style>
        body { font-family: Arial, Helvetica, sans-serif; font-size: 10pt; color: #222; margin: 20px; }
        h1 { font-size: 16pt; margin: 0 0 4px; }
        .meta { color: #666; font-size: 9pt; margin-bottom: 18px; }
        .filter-summary { font-size: 9pt; color: #444; margin-bottom: 12px; }
        .filter-summary span { display: inline-block; background: #eef; padding: 2px 6px; border-radius: 3px; margin-right: 6px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #999; padding: 4px 6px; vertical-align: top; }
        th { background: #eee; text-align: left; }
        .text-right { text-align: right; }
        .empty { padding: 12px; color: #777; text-align: center; }
        @@media print {
            .no-print { display: none; }
            body { margin: 8mm; }
            tr { page-break-inside: avoid; }
        }
    </style>
</head>
<body>
    <div class="no-print" style="text-align: right; margin-bottom: 12px;">
        <button onclick="window.print()">@T("Plugins.Misc.Moknik.Inventory.Action.Print")</button>
    </div>
    <h1>@T("Plugins.Misc.Moknik.Inventory.Tab.Inventory")</h1>
    <div class="meta">@DateTime.Now.ToString("yyyy-MM-dd HH:mm") · @Model.Inventory.Count @T("Plugins.Misc.Moknik.Inventory.PrintRowCountLabel")</div>

    @if (!string.IsNullOrEmpty(manufacturerName) || !string.IsNullOrEmpty(categoryName))
    {
        <div class="filter-summary">
            @if (!string.IsNullOrEmpty(manufacturerName))
            {
                <span><strong>@T("Plugins.Misc.Moknik.Inventory.Filter.Manufacturer"):</strong> @manufacturerName</span>
            }
            @if (!string.IsNullOrEmpty(categoryName))
            {
                <span><strong>@T("Plugins.Misc.Moknik.Inventory.Filter.Category"):</strong> @categoryName</span>
            }
        </div>
    }

    @if (!Model.Inventory.Any())
    {
        <div class="empty">@T("Plugins.Misc.Moknik.Inventory.Empty")</div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>@T("Plugins.Misc.Moknik.Inventory.Column.Manufacturer")</th>
                    <th>@T("Plugins.Misc.Moknik.Inventory.Column.Product")</th>
                    <th>@T("Plugins.Misc.Moknik.Inventory.Column.Sku")</th>
                    <th>@T("Plugins.Misc.Moknik.Inventory.Column.Ean")</th>
                    <th class="text-right">@T("Plugins.Misc.Moknik.Inventory.Column.Stock")</th>
                    <th class="text-right">@T("Plugins.Misc.Moknik.Inventory.Column.Reserved")</th>
                    <th>@T("Plugins.Misc.Moknik.Inventory.Column.Categories")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Inventory)
                {
                    <tr>
                        <td>@row.ManufacturerName</td>
                        <td>@row.ProductName</td>
                        <td>@row.Sku</td>
                        <td>@row.Ean</td>
                        <td class="text-right"><strong>@row.StockQuantity</strong></td>
                        <td class="text-right">@row.ReservedQuantity</td>
                        <td>@row.Categories</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    <script>
        window.addEventListener('load', function () { window.print(); });
    </script>
</body>
</html>
